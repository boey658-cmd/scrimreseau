DISCORD_TOKEN=votre_token_bot
CLIENT_ID=id_application_discord
# Guilde « assets » : upload des emojis jeu (npm run upload-emojis) — le bot doit pouvoir gérer les emojis sur ce serveur
# ASSET_GUILD_ID=
# Dev : plusieurs guildes (virgules), déploiement instantané par guilde
# GUILD_IDS=id_guilde_1,id_guilde_2
# Alternative : une seule guilde (toujours supporté)
# GUILD_ID=
# Dev — nettoyage manuel (ne pas activer par défaut) :
# Efface les commandes globales, puis (si GUILD_IDS/GUILD_ID) chaque guilde, puis redéploie selon le mode.
# CLEAR_ALL_COMMANDS_BEFORE_DEPLOY=1
# Efface uniquement les commandes des guildes ciblées (pas le global), puis redéploie en mode guilde.
# CLEAR_GUILD_COMMANDS_BEFORE_DEPLOY=1
# Prod : laisser GUILD_IDS et GUILD_ID vides → déploiement global (~1 h de propagation)
# Optionnel : lien (https://) vers le serveur Discord ScrimRéseau — bouton sous les annonces scrim ; vide = pas de bouton
# SCRIM_COMMUNITY_SERVER_URL=
# Seuil minimum de membres pour configurer le salon de réception scrim (/scrim-config channel set, sans bypass). Entier > 0 ; absent ou invalide → 150.
# SCRIM_RECEPTION_MIN_MEMBERS=150
# Prod : URL https (ticket / serveur de liaison) pour le message de refus « réception scrim » (/scrim-config channel set, serveur sous le seuil sans bypass). À renseigner en prod ; sinon affichage du placeholder [ton lien].
# SCRIM_RECEPTION_TICKET_URL=
# Optionnel : chemin du fichier SQLite (défaut : data/scrim.db)
# SQLITE_PATH=
# Active les logs debug d'autocomplete (recherche-scrim)
# SCRIM_DEBUG_AUTOCOMPLETE=false
# Guilde où /scrim-dev est enregistrée (commandes guilde uniquement) — invisible sur les autres serveurs
# DEV_GUILD_ID=
# Développeur (snowflake) — exécution de /scrim-dev (blacklist) uniquement
# BOT_DEV_ID=
# Salon (ID) pour les signalements /spammer
# SPAM_REPORT_CHANNEL_ID=
# Salon (ID) — rapport quotidien dev (embed résumé 24 h) ; vide = job désactivé
# DEV_DAILY_REPORT_CHANNEL_ID=
# Anti-spam création /recherche-scrim (succès DB + ≥1 envoi comptabilisé via scrim_posts)
# SCRIM_CREATION_BURST_COOLDOWN_SECONDS=45
# SCRIM_CREATION_WINDOW_MINUTES=30
# SCRIM_CREATION_WINDOW_LIMIT=8
# Intervalle (minutes) du job d’expiration des recherches actives /recherche-scrim (défaut : 30)
# SCRIM_EXPIRATION_CHECK_INTERVAL_MINUTES=30
# Délai (ms) entre deux appels Discord sérialisés (édits embeds scrim + envois diffusion) — 0–5000, défaut 100
# DISCORD_TASK_QUEUE_DELAY_MS=100
# Tentatives max par tâche dans la file (retry 429 / transitoire avant échec propagé), défaut 4
# DISCORD_TASK_QUEUE_MAX_ATTEMPTS=4
# Tentatives max pour runTransientDiscord (réponses interaction, prefetch hors file), défaut 4
# DISCORD_API_MAX_ATTEMPTS=4
# Logs détaillés file / API Discord (true/1/yes) — désactivé par défaut
# DISCORD_REQUEST_DEBUG=false
# Logs Discord (embeds) — optionnel ; chaîne vide = désactivé pour cette catégorie
# Schéma recommandé (bêta / serveur dev) — séparer erreurs, avertissements, événements métier, cycle de vie
DISCORD_LOG_ERROR_CHANNEL_ID=
DISCORD_LOG_WARN_CHANNEL_ID=
DISCORD_LOG_EVENT_CHANNEL_ID=
DISCORD_LOG_HEALTH_CHANNEL_ID=
# Compatibilité : si les DISCORD_LOG_* ci-dessus sont vides, le bot utilise encore :
# LOG_ERROR_CHANNEL_ID=
# LOG_WARNING_CHANNEL_ID=
